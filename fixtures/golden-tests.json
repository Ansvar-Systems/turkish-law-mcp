{
  "$schema": "./golden-tests.schema.json",
  "version": "2.0",
  "mcp_name": "Turkish Law MCP",
  "description": "Golden contract tests for the Turkish Law MCP covering 994 Turkish laws — Kanunlar, KHK, Cumhurbaşkanlığı Kararnameleri — from mevzuat.gov.tr with 21,732 provisions and 3,819 definitions",
  "tests": [
    {
      "id": "tr-001",
      "category": "article_retrieval",
      "description": "Retrieve Madde 1 of KVKK (Law No. 6698) -- purpose of the Personal Data Protection Law (amaç)",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Kişisel Verilerin Korunması Kanunu",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["kişisel veri", "koruma", "işlenmesi"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "tr-002",
      "category": "article_retrieval",
      "description": "Retrieve Madde 1 of İklim Kanunu (Law No. 7552) -- purpose of the Climate Law",
      "tool": "get_provision",
      "input": {
        "law_identifier": "İklim Kanunu",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["iklim", "sera gazı", "emisyon"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "tr-003",
      "category": "article_retrieval",
      "description": "Retrieve Madde 1 of Siber Güvenlik Kanunu (Law No. 7545) -- purpose of the Cybersecurity Law",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Siber Güvenlik Kanunu",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["siber", "güvenlik"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "tr-004",
      "category": "article_retrieval",
      "description": "Retrieve Madde 20 of the Constitution (Law No. 2709) -- right to privacy",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Türkiye Cumhuriyeti Anayasası",
        "article": "20"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["özel hayat", "kişisel veri"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "tr-005",
      "category": "search",
      "description": "Full-text search for 'kişisel veri' (personal data) returns KVKK provisions",
      "tool": "search_legislation",
      "input": {
        "query": "kişisel veri"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["kişisel veri", "koruma", "işleme"]
      }
    },
    {
      "id": "tr-006",
      "category": "search",
      "description": "Full-text search for 'siber güvenlik' (cybersecurity) returns related provisions",
      "tool": "search_legislation",
      "input": {
        "query": "siber güvenlik"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["siber", "güvenlik", "bilişim", "bilgi"]
      }
    },
    {
      "id": "tr-007",
      "category": "search",
      "description": "Full-text search for 'elektronik ticaret' (electronic commerce) returns provisions",
      "tool": "search_legislation",
      "input": {
        "query": "elektronik ticaret"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["elektronik ticaret", "ticari iletişim", "hizmet"]
      }
    },
    {
      "id": "tr-008",
      "category": "citation_roundtrip",
      "description": "Citation for KVKK Madde 3 includes mevzuat.gov.tr URL pattern",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Kişisel Verilerin Korunması Kanunu",
        "article": "3"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "mevzuat\\.gov\\.tr",
        "text_not_empty": true
      }
    },
    {
      "id": "tr-009",
      "category": "search",
      "description": "Full-text search for 'ceza' (penalty) returns penal code and other provisions",
      "tool": "search_legislation",
      "input": {
        "query": "ceza"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 5,
        "any_result_contains": ["ceza", "suç", "hapis"]
      }
    },
    {
      "id": "tr-010",
      "category": "search",
      "description": "Full-text search for 'veri sorumlusu' returns KVKK data controller provisions",
      "tool": "search_legislation",
      "input": {
        "query": "veri sorumlusu"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["veri sorumlusu", "kişisel veri"]
      }
    },
    {
      "id": "tr-011",
      "category": "negative_test",
      "description": "Non-existent Turkish law returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Kuantum Bilişim Kanunu 9999",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "tr-012",
      "category": "negative_test",
      "description": "Malformed article number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Kişisel Verilerin Korunması Kanunu",
        "article": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
